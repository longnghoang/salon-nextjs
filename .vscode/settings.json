{
  // General fallback formatter
  "editor.defaultFormatter": "vscode.typescript-language-features",
  "editor.formatOnSave": true,

  // Force Prettier for Vue files
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Force Prettier for JavaScript and TypeScript
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // For React .jsx files
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // For React .tsx files
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Use the C# extension for .NET files
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },

  // If you want to use Prettier for these files (Recommended)
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }

  // // Use the built-in JSON formatter
  // "[json]": {
  //   "editor.defaultFormatter": "vscode.json-language-features"
  // }
}
